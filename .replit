run = "node server/index.js"
entrypoint = "server/index.js"
modules = ["nodejs-22", "postgresql-16"]

[nix]
channel = "stable-24_05"
packages = ["nodejs_20"]

[[ports]]
localPort = 3000
externalPort = 80

[[ports]]
localPort = 8080
externalPort = 8080

[[ports]]
localPort = 8081
externalPort = 8081

[[ports]]
localPort = 8082
externalPort = 3002

[[ports]]
localPort = 23183
externalPort = 3000

[[ports]]
localPort = 25265
externalPort = 3001

[agent]
expertMode = true

[postMerge]
path = "scripts/post-merge.sh"
timeoutMs = 180000

[workflows]
runButton = "Project"

[deployment]
deploymentTarget = "autoscale"
build = ["pnpm", "install", "--frozen-lockfile"]
run = ["pnpm", "--filter", "@workspace/api-server", "run", "start"]
