<svg width="32" height="32" viewBox="0 0 32 32" xmlns="http://www.w3.org/2000/svg">
  <defs>
    <linearGradient id="cyanGrad" x1="0%" y1="0%" x2="100%" y2="100%">
      <stop offset="0%" style="stop-color:#00E5FF;stop-opacity:1" />
      <stop offset="100%" style="stop-color:#008291;stop-opacity:1" />
    </linearGradient>
  </defs>
  <style>
    @keyframes pulse {
      0%, 100% { filter: drop-shadow(0 0 2px #00E5FF); }
      50% { filter: drop-shadow(0 0 5px #00E5FF); }
    }
    .icon-x { animation: pulse 2s infinite; }
  </style>
  <rect width="32" height="32" rx="8" fill="#0A0A0F" />
  <g transform="translate(4, 4)" class="icon-x">
    <path d="M4 4 L20 20 M20 4 L4 20" stroke="url(#cyanGrad)" stroke-width="5" stroke-linecap="round"/>
    <path d="M17 7 L23 3 L19 10" fill="#00E5FF" />
  </g>
</svg>
