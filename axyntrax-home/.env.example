# =========================================================================
# AXYNTRAX AUTOMATION SUITE - VARIABLES DE ENTORNO (NEXT.JS 14)
# =========================================================================
# IMPORTANTE: No colocar credenciales reales en este archivo.
# Duplica este archivo como '.env.local' para tu entorno de desarrollo.
# Para producción, configura estas variables en el Dashboard de Vercel.
# =========================================================================

# -------------------------------------------------------------------------
# 1. FIREBASE (Cecilia IA Omnicanal)
# Public variables (expuestas al navegador para el cliente web)
# -------------------------------------------------------------------------
NEXT_PUBLIC_FIREBASE_API_KEY=your_firebase_api_key_here
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=your_project_id.firebaseapp.com
NEXT_PUBLIC_FIREBASE_PROJECT_ID=your_project_id

# Private key (solo servidor) - Usada por Firebase Admin SDK
# NOTA: En Vercel, asegúrate de mantener las comillas dobles o manejar los \n en el código.
FIREBASE_ADMIN_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nyour_private_key_here\n-----END PRIVATE KEY-----\n"

# -------------------------------------------------------------------------
# 2. DEEPSEEK API (IAs del ecosistema JARVIS)
# -------------------------------------------------------------------------
DEEPSEEK_API_KEY=sk-your_deepseek_api_key_here

# -------------------------------------------------------------------------
# 3. META GRAPH API (Omnicanalidad de Cecilia - WhatsApp/FB/IG)
# -------------------------------------------------------------------------
# Token permanente o temporal de acceso al Graph API
WSP_ACCESS_TOKEN=your_meta_graph_api_access_token_here

# ID del número de teléfono remitente (WhatsApp Business)
WSP_PHONE_NUMBER_ID=your_whatsapp_phone_number_id_here

# Token personalizado para validar la suscripción del Webhook en Meta
META_WEBHOOK_VERIFY_TOKEN=your_custom_secure_verify_token_here

# -------------------------------------------------------------------------
# 4. JARVIS OS PRIME & SISTEMA (Seguridad e Infraestructura)
# -------------------------------------------------------------------------
# Secreto largo para firmar/validar cookies o JWTs del panel de Jarvis
# Generar localmente con: openssl rand -base64 32
JARVIS_SESSION_SECRET=your_secure_random_session_secret_here

# Credenciales de acceso al Panel JARVIS (reemplaza los valores por defecto)
JARVIS_USER=your_jarvis_username_here
JARVIS_PASS=your_jarvis_password_here

# Cadena de conexión a la base de datos maestra (ej. PostgreSQL / Supabase)
DATABASE_URL=postgresql://user:password@your-database-host:6543/postgres

# -------------------------------------------------------------------------
# 5. CRON JOBS (Seguridad de endpoints internos)
# -------------------------------------------------------------------------
# Token maestro para autorizar llamadas a /api/cron/* desde Vercel Cron
# Generar con: openssl rand -hex 32
MASTER_TOKEN=your_secure_master_token_here

# -------------------------------------------------------------------------
# 6. META GRAPH API - Facebook & Instagram (Agente MARK + Cecilia Omnicanal)
# -------------------------------------------------------------------------
# Token de acceso a Meta Graph API (largo plazo, para páginas de FB e IG)
META_GRAPH_ACCESS_TOKEN=your_meta_graph_long_lived_token_here

# Token de acceso específico de la Página de Facebook
FB_PAGE_ACCESS_TOKEN=your_facebook_page_access_token_here

# Token de acceso específico de Instagram Business
IG_ACCESS_TOKEN=your_instagram_access_token_here

# ID numérico de la Página de Facebook (visible en Configuración → Página)
FB_PAGE_ID=your_facebook_page_id_here

# ID numérico de la cuenta de Instagram Business vinculada
IG_ACCOUNT_ID=your_instagram_account_id_here
