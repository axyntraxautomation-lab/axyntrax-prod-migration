    { "src": "/api", "dest": "/api/index.js" },
    { "src": "/registro", "dest": "/api/index.js" },
    { "src": "/login", "dest": "/api/index.js" },
    { "src": "/auth/(.*)", "dest": "/api/index.js" },
    { "src": "/link", "dest": "/link.html" },
    { "src": "/voice", "dest": "/voice.html" },
    { "src": "/jarvis", "dest": "/jarvis.html" },
    { "src": "/keygen", "dest": "/keygen.html" },
    { "src": "/atlas", "dest": "/atlas.html" }
  ]
}
