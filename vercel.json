{
  "version": 2,
  "cleanUrls": true,
  "rewrites": [
    { "source": "/", "destination": "/index.html" },
    { "source": "/registro", "destination": "/api/index.js" },
    { "source": "/login", "destination": "/api/index.js" },
    { "source": "/auth/(.*)", "destination": "/api/index.js" },
    { "source": "/api/(.*)", "destination": "/api/index.js" },
    { "source": "/api", "destination": "/api/index.js" },
    { "source": "/link", "destination": "/link.html" },
    { "source": "/voice", "destination": "/voice.html" },
    { "source": "/jarvis", "destination": "/jarvis.html" },
    { "source": "/keygen", "destination": "/keygen.html" }
  ]
}
