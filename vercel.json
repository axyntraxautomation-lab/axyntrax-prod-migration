{
  "version": 2,
  "builds": [
    { "src": "public/index.html", "use": "@vercel/static" },
    {
      "src": "api/index.js",
      "use": "@vercel/node",
      "config": { "includeFiles": "public/AXYNTRAX_Installer.bat" }
    }
  ],
  "routes": [
    { "src": "/api/(.*)", "dest": "/api/index.js" },
    { "src": "/(.*)", "dest": "/public/$1" }
  ]
}
